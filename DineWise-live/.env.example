PORT=3017
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# Optional platform connectors. These are intentionally generic because
# Swiggy and Zomato do not provide a simple public official API for this use case.
# If you have your own proxy/provider, configure the endpoint templates below.
SWIGGY_PROVIDER_URL=
ZOMATO_PROVIDER_URL=
